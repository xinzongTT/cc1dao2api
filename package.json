{
  "name": "commandcode-proxy",
  "version": "1.0.0",
  "type": "module",
  "description": "Command Code → OpenAI 兼容代理",
  "license": "MIT",
  "main": "proxy.mjs",
  "scripts": {
    "start": "node server/index.mjs",
    "dev": "node --watch server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "vite build --config web/vite.config.js",
    "build": "npm run build:web",
    "docker:build": "docker build -t commandcode-proxy:latest .",
    "docker:build:multi": "docker buildx build --platform linux/amd64,linux/arm64 -t commandcode-proxy:latest ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cookie": "^2.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
